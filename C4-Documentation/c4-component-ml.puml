@startuml C4_Component_ML
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title C4 Component Diagram — ML Subsystem only\n(inference + training + drift DAGs)

Person(client, "Client", "Uploads a storefront image\nfor industry classification")

System_Ext(hf, "Hugging Face Hub", "Punnarunwuwu/seml-industry-ver\n(train_v1, train_v2, test)")
System_Ext(tv, "torchvision", "EfficientNetV2-S & ResNet34\npretrained weights")

ContainerDb(predictions_db, "prediction_logs", "PostgreSQL 13", "Predictions + reviewer labels\n(image_bytes, predicted_class,\nfinal_class, brightness, blur)")
ContainerDb(mlflow_store, "MLflow store", "SQLite + filesystem", "Experiment runs, params,\nmetrics, pickled artifacts")
ContainerDb(pointer, "current_model.json", "JSON on shared mlruns volume", "{pca_pkl_path, clf_pkl_path,\nrun_id, test_f1, promoted_at}")
ContainerDb(baseline, "baseline_reference.json", "JSON on shared data volume", "Reference distributions for\nPSI and CSI computation")

Container_Boundary(api, "FastAPI — ML Inference  (host, Python 3.14+)") {
    Component(predict_ep, "predict endpoint", "FastAPI · api/main.py:predict", "POST /api/v1/predict —\nthe inference entry point")
    Component(reload_ep, "admin_reload endpoint", "FastAPI · api/main.py:admin_reload", "POST /api/v1/admin/reload —\nre-reads pointer, swaps models")
    Component(loader, "Model Pointer Loader", "api/main.py:load_model_pointer", "Reads current_model.json;\nfalls back to legacy paths")
    Component(backbone, "Backbone", "torchvision EfficientNetV2-S", "classifier → Identity,\n1280-dim feature extractor")
    Component(pca, "PCA", "pickled sklearn", "1280 → 256 dims")
    Component(clf, "Classifier", "pickled sklearn LogReg", "Predicts class + softmax\n(threshold 0.60 flags review)")
    Component(metrics, "Image-quality metrics", "api/monitoring.py", "compute_brightness,\ncompute_blur_score — drift inputs")
    Component(pred_log, "Prediction Logger", "api/monitoring.py:append_prediction_log", "INSERT row into\nprediction_logs")
}

Container_Boundary(drift_dag, "Airflow DAG — drift_detection_pipeline  (@daily)") {
    Component(drift_bootstrap, "bootstrap_baseline", "PythonOperator", "Creates baseline_reference.json\nfrom earliest 500 rows")
    Component(drift_compute, "compute_drift_report", "PythonOperator", "PSI + CSI(brightness, blur)\n+ rejection_rate over 7 days")
    Component(drift_branch, "branch_on_drift", "BranchPythonOperator", "Persistence (3-of-5) +\nCooldown (7d) gates")
    Component(drift_trigger, "trigger_model_retraining", "TriggerDagRunOperator", "Fires model_training_pipeline")
}

Container_Boundary(train_dag, "Airflow DAG — model_training_pipeline  (on trigger)") {
    Component(train_extract, "extract_features_task", "PythonOperator", "HF splits + reviewed rows,\nbackbone forward pass, save .npy")
    Component(train_grid, "train_and_log_task", "PythonOperator + MLflow", "4-way grid: PCA(256)+LogReg,\npicks best test-F1,\nwrites current_model.json")
    Component(train_baseline, "regenerate_baseline_task", "PythonOperator", "Deletes baseline_reference.json\nso drift re-bootstraps")
}

' ── Inference path ──
Rel(client, predict_ep, "Upload image", "HTTPS multipart")
Rel(predict_ep, metrics, "brightness / blur")
Rel(predict_ep, backbone, "Forward pass")
Rel(backbone, pca, "1280-dim features")
Rel(pca, clf, "256-dim features")
Rel(predict_ep, pred_log, "Log prediction")
Rel(pred_log, predictions_db, "INSERT", "SQL")
Rel(reload_ep, loader, "Swap models")
Rel(loader, pointer, "Read", "filesystem")
Rel(backbone, tv, "Pretrained weights\n(first run)", "HTTPS")

' ── Drift path ──
Rel(drift_bootstrap, predictions_db, "SELECT earliest 500", "SQL")
Rel(drift_bootstrap, baseline, "Write if missing", "filesystem")
Rel(drift_compute, predictions_db, "SELECT last 7 days\n+ review counts", "SQL")
Rel(drift_compute, baseline, "Read reference dist", "filesystem")
Rel(drift_compute, drift_branch, "Drift report", "XCom + JSON")
Rel(drift_branch, drift_trigger, "If gates pass")
Rel(drift_trigger, train_extract, "TriggerDagRun:\nmodel_training_pipeline")

' ── Training path ──
Rel(train_extract, hf, "load_dataset", "HTTPS")
Rel(train_extract, predictions_db, "Pull approved/rejected\nas labeled data", "SQL")
Rel(train_extract, tv, "Backbone weights", "cached")
Rel(train_extract, train_grid, "Extracted features (.npy)")
Rel(train_grid, mlflow_store, "log_params, log_metrics,\nlog_model", "MLflow API")
Rel(train_grid, pointer, "Write winning run's\nartifact paths", "filesystem")
Rel(train_grid, train_baseline, "Chain")
Rel(train_baseline, baseline, "Delete\n(next drift re-bootstraps)", "filesystem")

@enduml
